# ==============================
# Google OAuth（ユーザーログイン用）
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアントID
# ==============================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ==============================
# NextAuth
# ==============================
NEXTAUTH_URL=http://localhost:3000
# 以下のコマンドで生成: openssl rand -base64 32
NEXTAUTH_SECRET=

# ==============================
# 管理者メールアドレス（カンマ区切りで複数指定可）
# ==============================
ALLOWED_EMAILS=tamae.kobayashi.league@gmail.com

# ==============================
# Google サービスアカウント（Sheets API用）
# Google Cloud Console > サービスアカウント > キー作成 > JSON
# JSONファイルの内容を1行にしてそのまま貼り付け
# ==============================
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ==============================
# Google スプレッドシート
# ==============================
SPREADSHEET_ID=1NsuU_7lly8f7gYpik8Hun_5F_rjPTCXieQCb8cFI62M

# ==============================
# OpenAI
# ==============================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
